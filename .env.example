# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/agency_db?schema=public"
DATABASE_URL_TEST="postgresql://postgres:password@localhost:5432/agency_test?schema=public"

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────────────────────
# NestJS API
# ─────────────────────────────────────────────────────────────
API_PORT=4000
API_URL="http://localhost:4000"

JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-to-another-long-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# ─────────────────────────────────────────────────────────────
# Phoenix Orchestrator
# ─────────────────────────────────────────────────────────────
ORCHESTRATOR_URL="http://localhost:4001"
ORCHESTRATOR_SECRET="change-me-orchestrator-secret"
PHX_SECRET_KEY_BASE="change-me-to-64-char-random-string"
PHX_HOST="localhost"
PHX_PORT=4001

# ─────────────────────────────────────────────────────────────
# Next.js Admin UI (apps/web)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-nextauth-secret"

# ─────────────────────────────────────────────────────────────
# Next.js Client Portal (apps/portal)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_PORTAL_API_URL="http://localhost:4000"
PORTAL_NEXTAUTH_URL="http://localhost:3001"
PORTAL_NEXTAUTH_SECRET="change-me-portal-nextauth-secret"

# ─────────────────────────────────────────────────────────────
# LLM providers (multi-vendor — pick per task)
# ─────────────────────────────────────────────────────────────
# Set one or more provider keys. If none are set, LLM-dependent
# services fall back to dry-run (template) mode.
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""
OPENROUTER_API_KEY=""

# Model routing — "<provider>:<modelId>".
# providers: anthropic | openai | google | openrouter
# Per-task overrides (LLM_MODEL_PM, LLM_MODEL_TRIAGE, ...) take precedence;
# otherwise LLM_MODEL_DEFAULT is used.
LLM_MODEL_DEFAULT="anthropic:claude-sonnet-4-5"
LLM_MODEL_PM="anthropic:claude-sonnet-4-5"
LLM_MODEL_TRIAGE="openai:gpt-4o-mini"
LLM_MODEL_SUMMARIZE="google:gemini-2.0-flash"
LLM_MODEL_CODE="anthropic:claude-sonnet-4-5"
LLM_MODEL_TEST="openai:gpt-4o-mini"

# Legacy (kept for any direct consumers — new code should use LLM_MODEL_*)
CLAUDE_MODEL="claude-sonnet-4-5"

# ─────────────────────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────────────────────
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="agency-artifacts"
CLOUDFRONT_DOMAIN="https://your-distribution.cloudfront.net"

# ─────────────────────────────────────────────────────────────
# GitHub
# ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=""
GITHUB_ORG=""

# ─────────────────────────────────────────────────────────────
# Figma
# ─────────────────────────────────────────────────────────────
FIGMA_ACCESS_TOKEN=""

# ─────────────────────────────────────────────────────────────
# Sentry
# ─────────────────────────────────────────────────────────────
SENTRY_DSN=""
SENTRY_WEBHOOK_SECRET=""

# ─────────────────────────────────────────────────────────────
# Notifications (SMTP / Slack)
# ─────────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@your-agency.com"

SLACK_BOT_TOKEN=""
SLACK_CHANNEL_ALERTS=""

# ─────────────────────────────────────────────────────────────
# Agent (장비별 에이전트)
# ─────────────────────────────────────────────────────────────
AGENT_TYPE="MAC_DEV"
AGENT_ID="mac-agent-01"
AGENT_ENDPOINT="wss://mac-agent-01.internal:4002/a2a"
AGENT_HEARTBEAT_INTERVAL_MS=30000
