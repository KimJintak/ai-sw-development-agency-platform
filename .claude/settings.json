{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote -v)",
      "Bash(git rev-parse*)",
      "Bash(pnpm --filter *:exec tsc --noEmit*)",
      "Bash(pnpm --filter * exec tsc --noEmit*)",
      "Bash(pnpm --filter * exec prisma generate)",
      "Bash(aws sts get-caller-identity*)",
      "Bash(node --version)",
      "Bash(node --env-file=.env apps/api/scripts/smoke-llm.mjs*)",
      "Bash(curl -s -X PUT http://169.254.169.254/latest/api/token*)",
      "Bash(curl -s -H X-aws-ec2-metadata-token:*)",
      "Bash(kill 1089741 1089982)",
      "Bash(echo \"New PID: $!\")",
      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\('✅ 로그인 OK' if 'accessToken' in d else f'❌ {d}'\\)\")",
      "Bash(python3 -c ' *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(curl -s http://localhost:4000/api/projects)",
      "Bash(python3 -c \"import json,sys; data=json.load\\(sys.stdin\\); [print\\(f'id={p[\\\\\"id\\\\\"]} name={p[\\\\\"name\\\\\"]} createdAt={p[\\\\\"createdAt\\\\\"]}'\\) for p in data.get\\('data', data\\) if 'Woojoo' in p.get\\('name',''\\) or 'CRM' in p.get\\('name',''\\)]\")",
      "Bash(python3 -c \"import json,sys; data=json.load\\(sys.stdin\\); print\\(json.dumps\\(data, indent=2, ensure_ascii=False\\)[:3000]\\)\")",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(json.dumps\\(d, indent=2, ensure_ascii=False\\)\\)\")"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/stop.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
